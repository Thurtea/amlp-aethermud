inherit "/std/object";

mapping exits;
mapping room_items;

void create() {
    set_exits(([]));
    set_items(([]));
}

mapping query_exits() { return exits; }
void set_exits(mapping e) { exits = e; }
void add_exit(string d, string dest) { exits[d] = dest; }

mapping query_items() { return room_items; }
void set_items(mapping i) { room_items = i; }

